# ─────────────────────────────────────────────────────────────
# Environment configuration for AI Product Growth Analytics
# Copy this file to `.env` and fill in real values.
# ─────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=growth_analytics
POSTGRES_USER=analytics
POSTGRES_PASSWORD=analytics

# Raw data location (Kaggle: eCommerce Behavior Data from Multi Category Store)
RAW_DATA_PATH=data/raw/ecommerce_events.csv
PROCESSED_DATA_DIR=data/processed

# AI layer ("openai" or "gemini"). Leave keys blank to use the offline rule-based fallback.
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
